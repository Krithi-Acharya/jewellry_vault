// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int      @id @default(autoincrement()) @map("usr_id")
  firebaseUid     String?  @unique @map("usr_firebase_uid")
  email           String   @unique @map("usr_email")
  phoneNumber     String?  @unique @map("usr_phone_number")
  password        String?  @map("usr_password")
  gender          String?  @map("usr_gender")
  
  @@map("USERS")
}
